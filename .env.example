# iVisa CSOV Dashboard — Environment Variables
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.

# SEMrush API key (phrase_organic endpoint)
SEMRUSH_API_KEY=your_semrush_api_key_here

# Ahrefs API key (v3 SERP overview)
AHREFS_API_KEY=your_ahrefs_api_key_here

# Anthropic Claude API key (claude-3-haiku-20240307)
CLAUDE_API_KEY=your_claude_api_key_here

# Google Gemini API key (gemini-1.5-flash)
GEMINI_API_KEY=your_gemini_api_key_here

# SerpAPI key for Google AI Overview scraping (https://serpapi.com)
# Free tier: 100 searches/month. Hobby plan ($50/mo): 5,000 searches/month.
# Leave blank to use neutral baseline (50) for AI Overview component.
SERPAPI_KEY=your_serpapi_key_here

# Slack Incoming Webhook URL for Friday report notifications
SLACK_WEBHOOK_URL=your_slack_webhook_here

# GitHub Pages URL for the live dashboard
GITHUB_PAGES_URL=https://paulavotobernales-94.github.io/ivisa-csov
